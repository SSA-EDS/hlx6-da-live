# AMS environment configuration for da-live
# Source the appropriate terraform env file, then run: node build.js
#
# Example:
#   source /path/to/ams-eds-terraform/environments/ent-aem.env && npm run build:env
#   source /path/to/ams-eds-terraform/environments/eds-can.env && npm run build:env

# AEM CDN host for preview (branch--repo--org.<value>)
HLX_PROD_SERVER_HOST_PAGE=entmseds.page

# AEM CDN host for live/production (branch--repo--org.<value>)
HLX_PROD_SERVER_HOST_LIVE=entmseds.live
